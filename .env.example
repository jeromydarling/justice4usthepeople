# =============================================================================
# All env vars are PUBLIC and inlined at build time (static export, no server).
# Set them as GitHub Actions repository secrets / variables for production.
# =============================================================================

# Site
NEXT_PUBLIC_SITE_URL=https://justice4usthepeople.org
NEXT_PUBLIC_SITE_NAME="Justice 4 Us The People"

# GitHub Pages: leave empty for custom domain; set to "/repo-name" for project pages.
NEXT_PUBLIC_BASE_PATH=

# -----------------------------------------------------------------------------
# Forms — Cloudflare Worker endpoint (see /worker)
# -----------------------------------------------------------------------------
# Deploy the Worker once with `wrangler deploy` from /worker, then paste its
# URL here. Every form on the site POSTs here; the Worker creates a GitHub
# Issue per submission in your private submissions repo.
NEXT_PUBLIC_FORM_ENDPOINT=https://j4utp-forms.example.workers.dev

# -----------------------------------------------------------------------------
# Stripe — using Payment Links (no server, GitHub-Pages-friendly).
# Create each link in the Stripe dashboard, then paste the URL here.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_DONATE_25=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_DONATE_50=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_DONATE_100=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_DONATE_250=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_DONATE_CUSTOM=https://buy.stripe.com/test_xxx

NEXT_PUBLIC_STRIPE_MEMBERSHIP_MONTHLY=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_MEMBERSHIP_ANNUAL=https://buy.stripe.com/test_xxx

# Store products (one Payment Link per SKU)
NEXT_PUBLIC_STRIPE_YARDSIGN=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_TSHIRT=https://buy.stripe.com/test_xxx
NEXT_PUBLIC_STRIPE_BUTTON_PACK=https://buy.stripe.com/test_xxx

# -----------------------------------------------------------------------------
# Mapbox — required for the Get Help map. Free tier is plenty.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...

# -----------------------------------------------------------------------------
# News aggregator
# -----------------------------------------------------------------------------
# rss2json public endpoint works without an API key for low volume.
# If you hit rate limits, sign up at rss2json.com and add an API key.
NEXT_PUBLIC_RSS2JSON_API_KEY=
